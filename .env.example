# Site URL — controls metadata, sitemap, robots, and canonical URLs.
# Staging: use your Vercel preview URL
# Production: https://islandrentalcarts.com
NEXT_PUBLIC_SITE_URL=https://island-rental-carts.vercel.app

# Sanity CMS — this project uses the project below. In sanity.io/manage → API → CORS origins,
# add http://localhost:3000 (and your Vercel/preview URLs). Project ID is not secret (see .cursor/SANITY_DASHBOARD_CONTEXT.md).
NEXT_PUBLIC_SANITY_PROJECT_ID=oe6l4tp6
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: set to "true" to show the Vision (GROQ) tab in Sanity Studio (hidden in production by default)
# NEXT_PUBLIC_SANITY_SHOW_VISION=true

# Sanity write token — required only for seeding content (npm run seed-sanity). Create at sanity.io/manage → API → Tokens (Editor).
# SANITY_API_TOKEN=

# Secret for on-demand revalidation — set in Vercel and add a Sanity webhook that POSTs to https://your-site.com/api/revalidate with this secret so the site updates when you publish in Sanity.
# SANITY_REVALIDATE_SECRET=
